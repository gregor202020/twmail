# =============================================================================
# Third Wave Mail — Environment Variables
# Copy this file to .env and fill in production values.
# =============================================================================

# --------------------------------------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------------------------------------
POSTGRES_USER=twmail
POSTGRES_PASSWORD=twmail_dev_password
POSTGRES_DB=twmail
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Connection string used by API and workers (via PgBouncer)
DATABASE_URL=postgresql://twmail:twmail_dev_password@pgbouncer:6432/twmail

# --------------------------------------------------------------------------
# Redis
# --------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# --------------------------------------------------------------------------
# API Server
# --------------------------------------------------------------------------
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# --------------------------------------------------------------------------
# JWT Authentication
# --------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# --------------------------------------------------------------------------
# Rate Limiting
# --------------------------------------------------------------------------
RATE_LIMIT_DASHBOARD=100
RATE_LIMIT_API_KEY=1000
RATE_LIMIT_WINDOW_MS=60000

# --------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------
LOG_LEVEL=info

# --------------------------------------------------------------------------
# AWS SES (Simple Email Service)
# --------------------------------------------------------------------------
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_CONFIGURATION_SET=marketing
SES_SENDING_DOMAIN=thirdwavebbq.com.au

# --------------------------------------------------------------------------
# Application
# --------------------------------------------------------------------------
BASE_URL=https://mail.thirdwavebbq.com.au
ASSETS_DIR=/data/assets
ALLOWED_ORIGINS=

# --------------------------------------------------------------------------
# SSL (for nginx container)
# --------------------------------------------------------------------------
SSL_CERT_PATH=./nginx/certs/fullchain.pem
SSL_KEY_PATH=./nginx/certs/privkey.pem

# --------------------------------------------------------------------------
# Monitoring (optional)
# --------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
UPTIME_MONITOR_URL=
