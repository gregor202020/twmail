# Database
POSTGRES_USER=twmail
POSTGRES_PASSWORD=twmail_dev_password
POSTGRES_DB=twmail
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://twmail:twmail_dev_password@pgbouncer:6432/twmail

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# API Server
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_DASHBOARD=100
RATE_LIMIT_API_KEY=1000
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
