{
  "name": "third-wave-mail",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/workers",
    "packages/frontend"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:workers": "npm run dev --workspace=packages/workers",
    "dev:frontend": "npm run dev --workspace=packages/frontend",
    "build": "npm run build --workspaces",
    "test": "npm test --workspace=packages/api",
    "lint": "eslint packages/api/src packages/workers/src packages/shared/src",
    "format": "prettier --write \"packages/{api,workers,shared}/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/{api,workers,shared}/src/**/*.ts\"",
    "db:migrate": "node scripts/migrate.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0"
  }
}
